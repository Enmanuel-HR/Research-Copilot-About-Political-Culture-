  "evaluation_metrics": {
    "metric_1": {
      "name": "Citation Accuracy",
      "description": "Percentage of citations that are accurate and properly formatted",
      "target": 0.95,
      "weight": 0.20
    },
    "metric_2": {
      "name": "Answer Relevance",
      "description": "Relevance of answer to question (1-5 scale)",
      "target": 4.0,
      "weight": 0.20
    },
    "metric_3": {
      "name": "Hallucination Rate",
      "description": "Percentage of information not found in papers (should be < 5%)",
      "target": 0.02,
      "weight": 0.20
    },
    "metric_4": {
      "name": "Completeness",
      "description": "How complete/comprehensive the answer is (1-5 scale)",
      "target": 4.0,
      "weight": 0.15
    },
    "metric_5": {
      "name": "Response Time",
      "description": "Average response time in seconds",
      "target": 3.0,
      "weight": 0.15
    },
    "metric_6": {
      "name": "Information Accuracy",
      "description": "Accuracy of factual claims (1-5 scale)",
      "target": 4.5,
      "weight": 0.10
    }
