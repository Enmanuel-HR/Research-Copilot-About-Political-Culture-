      "recommended_for": ["factual_questions"],
      "expected_metrics": ["machine_readability", "structured_output"]
    },
    "v3": {
      "name": "Few-Shot Learning",
      "recommended_for": ["analytical_questions", "synthesis_questions"],
      "expected_metrics": ["answer_quality", "narrative_flow"]
    },
    "v4": {
      "name": "Chain-of-Thought",
      "recommended_for": ["analytical_questions", "synthesis_questions"],
      "expected_metrics": ["reasoning_quality", "completeness", "transparency"]
    }
  },
  "evaluation_process": {
    "step_1": "Run each question through all 4 strategies (where applicable)",
